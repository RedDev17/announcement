# ============================================================================
# Copy to ".env" and fill in your values. The .env file is git-ignored.
# ============================================================================

# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=announcement
DB_USER=postgres
DB_PASS=your_local_postgres_password

# SSL mode (auto-detected): 'disable' for localhost/ngrok, 'require' for cloud.
# Override only if you need a specific mode.
# DB_SSLMODE=disable

# ===== File Storage =====
# 'local' = save files to /uploads/ folder (recommended)
# 'supabase' = save to Supabase Storage (only if SUPABASE_URL + SUPABASE_SERVICE_KEY set)
STORAGE_DRIVER=local

# Only fill in if STORAGE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ===== Auth =====
# Random string used to sign auth cookies. Use 64+ chars.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=replace-with-random-string-at-least-64-chars-long
