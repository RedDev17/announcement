# ============================================================================
# Copy this file to ".env" (without the .example) and fill in your values.
# The .env file is git-ignored so your secrets stay safe.
# ============================================================================

# ===== PostgreSQL Database =====
# Option A: LOCAL PostgreSQL (after installing PG on your machine)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=announcement
DB_USER=postgres
DB_PASS=your_local_postgres_password

# Option B: SUPABASE CLOUD (uncomment + comment Option A)
# DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.fddnruksiofxalrtypmk
# DB_PASS=your_supabase_password

# ===== Supabase Storage (for image/PDF uploads) =====
# Required even if using local PG, since uploads still go to Supabase Storage.
# Get these from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://fddnruksiofxalrtypmk.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ===== Auth =====
# Random string (64+ chars). Generate with: openssl rand -hex 32
AUTH_SECRET=replace_with_a_random_string_64_chars_or_more
