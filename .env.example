# ============================================================================
# Copy to ".env" and fill in your values. The .env file is git-ignored.
# ============================================================================

# ===== PostgreSQL =====
# Local PG (default for self-hosted):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=announcement
DB_USER=postgres
DB_PASS=your_local_postgres_password

# Or use Supabase Cloud (uncomment + comment local block above):
# DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.fddnruksiofxalrtypmk
# DB_PASS=your_supabase_password

# ===== File Storage =====
# 'local'    = save files to /uploads/ (no external service needed)
# 'supabase' = save to Supabase Storage (use this on Vercel)
STORAGE_DRIVER=local

# Only required if STORAGE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ===== Auth =====
# Random string used to sign auth cookies. Use 64+ chars in production.
AUTH_SECRET=replace-with-random-string-at-least-64-chars-long
